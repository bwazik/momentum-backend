{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {},
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "-y"
      ],
      "enabled": true
    },

    "laravel-boost": {
      "type": "local",
      "command": [
        "php",
        "D:/Projects/momentum/backend/artisan",
        "boost:mcp"
      ],
      "enabled": true
    },
  }
}
